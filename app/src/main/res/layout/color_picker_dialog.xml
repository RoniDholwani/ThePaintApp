<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:id="@+id/colorPickerRoot">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Color Picker"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="24dp"
        android:id="@+id/colorPickerTitle" />

    <!-- Color Preview -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="4dp"
        app:cardCornerRadius="16dp"
        android:layout_marginBottom="24dp"
        android:id="@+id/previewCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center">

            <View
                android:id="@+id/colorPreview"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/color_preview_bg" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selected Color"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/colorHexText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#212121"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/colorRGBText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RGB(33, 33, 33)"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Color Wheel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <com.example.rdthepaintapp.ColorWheelView
            android:id="@+id/colorWheelView"
            android:layout_width="250dp"
            android:layout_height="250dp" />
    </LinearLayout>

    <!-- Saturation Slider -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saturation"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"
        android:id="@+id/saturationLabel" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/saturation_min_icon"
            android:layout_marginEnd="12dp" />

        <SeekBar
            android:id="@+id/saturationSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="100"
            android:thumb="@drawable/seekbar_thumb_saturation" />

        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/saturation_max_icon"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Brightness Slider -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Brightness"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"
        android:id="@+id/brightnessLabel" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_brightness_low"
            android:layout_marginEnd="12dp" />

        <SeekBar
            android:id="@+id/brightnessSeekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:thumb="@drawable/seekbar_thumb_brightness" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_brightness_high"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="12dp"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelect"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Apply"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="12dp"
            android:layout_marginStart="12dp" />
    </LinearLayout>
</LinearLayout>